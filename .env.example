# ── Server ────────────────────────────────────────────────────────────────
# API server port. Kept separate from PORT so it can't collide with the web
# dev server (Vite) or a hosting platform's injected PORT.
API_PORT=3001

# ── Virtual try-on engine ───────────────────────────────────────────────────
# Which AI engine generates the try-on image.
#   mock      = no API needed; composites the garment over your photo (great for
#               testing the whole app flow on your phone with zero cost).
#   fashn     = FASHN.ai  (https://fashn.ai/api)
#   replicate = Replicate IDM-VTON (https://replicate.com/cuuupid/idm-vton)
TRYON_ENGINE=mock

# FASHN
FASHN_API_KEY=
FASHN_MODEL=tryon-v1.6

# Replicate
REPLICATE_API_TOKEN=
REPLICATE_VERSION=c871bb9b046607b680449ecbae55fd8c6d945e0a1948644bf2361b3d021d3ff4
